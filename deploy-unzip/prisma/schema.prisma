generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  TAILOR
}

enum QuoteStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum OrderProgressStatus {
  PENDING_APPROVAL
  AWAITING_PAYMENT
  CONFIRMED
  CUTTING
  STITCHING
  FINISHING
  READY
  DELIVERED
}

enum OrderStatusType {
  CREATED
  PENDING_TAILOR_REVIEW
  CLARIFICATION_REQUESTED
  REJECTED_BY_TAILOR
  QUOTE_REJECTED
  QUOTE_MODIFICATION_REQUESTED
  MEASUREMENTS_ADDED
  QUOTATION_SENT
  QUOTE_SENT
  QUOTE_ACCEPTED
  PAID
  IN_PROGRESS
  READY_FOR_TRIAL
  COMPLETED
  CANCELLED
}

enum DraftOrderStatus {
  DRAFT
}

model User {
  id            String  @id @default(cuid())
  name          String
  email         String  @unique
  password      String
  role          UserRole
  phone         String?
  address       String?
  customerOrders Order[] @relation("CustomerOrders")
  tailorOrders   Order[] @relation("TailorOrders")
  sentQuotes     Quote[] @relation("TailorQuotes")
  statusChanges  OrderStatus[]
  progressChanges OrderProgressUpdate[]
  draftOrders    DraftOrder[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Order {
  id              String          @id @default(cuid())
  customerId      String
  tailorId        String?
  title           String
  notes           String?
  eventDate       DateTime?
  deliveryDate    DateTime?
  currentStatus   OrderStatusType @default(CREATED)
  progressStatus  OrderProgressStatus @default(PENDING_APPROVAL)
  customer        User            @relation("CustomerOrders", fields: [customerId], references: [id])
  tailor          User?           @relation("TailorOrders", fields: [tailorId], references: [id])
  measurement     Measurement?
  customization   Customization?
  quote           Quote?
  payment         Payment?
  statusHistory   OrderStatus[]
  progressUpdates OrderProgressUpdate[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Measurement {
  id              String   @id @default(cuid())
  orderId         String   @unique
  chest           Decimal? @db.Decimal(8, 2)
  waist           Decimal? @db.Decimal(8, 2)
  hip             Decimal? @db.Decimal(8, 2)
  shoulder        Decimal? @db.Decimal(8, 2)
  sleeveLength    Decimal? @db.Decimal(8, 2)
  height          Decimal? @db.Decimal(8, 2)
  referenceImage  String?
  inseam          Decimal? @db.Decimal(8, 2)
  neck            Decimal? @db.Decimal(8, 2)
  notes           String?
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Customization {
  id              String   @id @default(cuid())
  orderId         String   @unique
  fabricType      String?
  color           String?
  style           String?
  embroideryText  String?
  addonDetails    String?
  notes           String?
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Quote {
  id              String      @id @default(cuid())
  orderId         String      @unique
  tailorId        String
  fabricCost      Decimal     @db.Decimal(10, 2)
  stitchingCost   Decimal     @db.Decimal(10, 2)
  embroideryCost  Decimal     @db.Decimal(10, 2)
  deliveryCost    Decimal     @db.Decimal(10, 2)
  totalPrice      Decimal     @db.Decimal(10, 2)
  estimatedDeliveryDays Int
  amount          Decimal     @db.Decimal(10, 2)
  currency        String      @default("USD")
  message         String?
  status          QuoteStatus @default(PENDING)
  validUntil      DateTime?
  order           Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  tailor          User        @relation("TailorQuotes", fields: [tailorId], references: [id])
  payment         Payment?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Payment {
  id                 String        @id @default(cuid())
  orderId            String        @unique
  quoteId            String?       @unique
  amount             Decimal       @db.Decimal(10, 2)
  currency           String        @default("USD")
  status             PaymentStatus @default(PENDING)
  provider           String?
  providerOrderId    String?       @unique
  transactionRef     String?       @unique
  paidAt             DateTime?
  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quote              Quote?        @relation(fields: [quoteId], references: [id])
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model OrderStatus {
  id              String          @id @default(cuid())
  orderId         String
  status          OrderStatusType
  note            String?
  changedByUserId String?
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy       User?           @relation(fields: [changedByUserId], references: [id])
  createdAt       DateTime        @default(now())

  @@index([orderId, createdAt])
}

model OrderProgressUpdate {
  id              String              @id @default(cuid())
  orderId         String
  status          OrderProgressStatus
  note            String?
  changedByUserId String?
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy       User?               @relation(fields: [changedByUserId], references: [id])
  createdAt       DateTime            @default(now())

  @@index([orderId, createdAt])
}

model Costume {
  id          String   @id @default(cuid())
  name        String
  category    String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DraftOrder {
  id           String           @id @default(cuid())
  userId       String
  fabric       String
  color        String
  sleeveStyle  String
  neckStyle    String
  length       String
  embroidery   String
  notes        String?
  status       DraftOrderStatus @default(DRAFT)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId, createdAt])
}
