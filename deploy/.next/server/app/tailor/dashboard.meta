{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/tailor/layout,_N_T_/tailor/dashboard/layout,_N_T_/tailor/dashboard/page,_N_T_/tailor/dashboard"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/tailor/dashboard/__PAGE__",
    "/tailor/dashboard",
    "/tailor",
    "/_index",
    "/_head"
  ]
}