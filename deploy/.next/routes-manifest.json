{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/customer/quotes/[orderId]/action",
      "regex": "^/api/customer/quotes/([^/]+?)/action(?:/)?$",
      "routeKeys": {
        "nxtPorderId": "nxtPorderId"
      },
      "namedRegex": "^/api/customer/quotes/(?<nxtPorderId>[^/]+?)/action(?:/)?$"
    },
    {
      "page": "/api/orders/[orderId]/measurements",
      "regex": "^/api/orders/([^/]+?)/measurements(?:/)?$",
      "routeKeys": {
        "nxtPorderId": "nxtPorderId"
      },
      "namedRegex": "^/api/orders/(?<nxtPorderId>[^/]+?)/measurements(?:/)?$"
    },
    {
      "page": "/api/tailor/orders/[orderId]/action",
