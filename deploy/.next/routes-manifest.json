      "routeKeys": {
        "nxtPorderId": "nxtPorderId"
      },
      "namedRegex": "^/api/tailor/orders/(?<nxtPorderId>[^/]+?)/action(?:/)?$"
    },
    {
      "page": "/api/tailor/orders/[orderId]/progress",
